{
  "name": "cv-autopilot-backend",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev:redis": "docker compose up -d redis",
    "dev:postgres": "docker compose up -d postgres",
    "dev:server": "bun --watch src/main.ts",
    "dev:worker": "bun --watch src/worker.ts",
    "dev": "concurrently -k -n api,worker,web \"bun run dev:server\" \"bun run dev:worker\" \"bun run --cwd ../../app/frontend dev\"",
    "build:backend": "nest build",
    "start": "bun dist/main.js",
    "start:worker": "bun dist/worker.js",
    "migration:generate": "bun node_modules/typeorm/cli.js migration:generate src/database/migrations/Generated.ts -d src/database/data-source.ts",
    "migration:run": "bun node_modules/typeorm/cli.js migration:run -d src/database/data-source.ts",
    "migration:revert": "bun node_modules/typeorm/cli.js migration:revert -d src/database/data-source.ts",
    "migration:show": "bun node_modules/typeorm/cli.js migration:show -d src/database/data-source.ts",
    "schema:baseline": "bun src/database/baseline.ts",
    "db:baseline": "bun src/database/baseline.ts",
    "db:migrate": "bun node_modules/typeorm/cli.js migration:run -d src/database/data-source.ts",
    "db:setup": "bun src/database/baseline.ts && bun node_modules/typeorm/cli.js migration:run -d src/database/data-source.ts",
    "test": "bun test",
    "smoke": "bun scripts/smoke.ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@nestjs/bullmq": "11.0.4",
    "@nestjs/common": "11.1.28",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/schedule": "6.1.3",
    "@nestjs/serve-static": "5.0.5",
    "@nestjs/typeorm": "^11.0.0",
    "bullmq": "^5.78.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "express": "^5.2.1",
    "ioredis": "^5.11.1",
    "node-latex": "^3.1.0",
    "pg": "^8.13.0",
    "playwright": "^1.52.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.24",
    "@nestjs/testing": "11.1.28",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "concurrently": "^10.0.3",
    "typescript": "^5.6.0"
  }
}
