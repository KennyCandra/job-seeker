{
  "name": "cv-autopilot",
  "version": "2.0.0",
  "devDependencies": {
    "concurrently": "^10.0.3"
  },
  "private": true,
  "scripts": {
    "dev:redis": "docker compose up -d redis",
    "dev:postgres": "docker compose up -d postgres",
    "dev:server": "bun run --cwd app/backend dev:server",
    "dev:worker": "bun run --cwd app/backend dev:worker",
    "dev": "concurrently -k -n services,api,worker,web \"docker compose up redis postgres\" \"bun run --cwd app/backend dev:server\" \"bun run --cwd app/backend dev:worker\" \"bun run --cwd app/frontend dev\"",
    "build:frontend": "bun run --cwd app/frontend build",
    "start": "bun run --cwd app/backend start",
    "start:worker": "bun run --cwd app/backend start:worker",
    "db:migrate": "bun run --cwd app/backend db:migrate",
    "db:setup": "bun run --cwd app/backend db:setup"
  },
  "type": "module"
}
